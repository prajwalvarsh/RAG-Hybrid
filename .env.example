# .env.example — copy to .env and fill in real values
# All keys map directly to Settings fields in config.py.

# LLM — Groq OpenAI-compatible endpoint
# Either variable name is accepted; GROQ_API_KEY is the canonical one.
# GROQ_API_KEY=                             # your Groq key (required)
# LLM_API_KEY=                              # alias — use one or the other
# LLM_API_BASE=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant

# Retrieval
# RETRIEVAL_TOP_K=50
# FUSION_TOP_K=20
# RERANK_TOP_K=5
# DEFAULT_COLLECTION=rag_hybrid

# Evaluation
# EVAL_SLEEP_SECONDS=3
# EVAL_LIMIT=0                              # 0 = run all questions

# Paths
# CHROMA_PATH=chroma_db
# GOLDEN_PATH=eval/golden/golden.json
